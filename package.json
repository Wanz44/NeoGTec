    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.454.0",
    "motion": "^12.39.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-hook-form": "^7.78.0",
    "recharts": "^2.15.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
