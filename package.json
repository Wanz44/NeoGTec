  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/backend/server.ts",
    "build": "vite build && esbuild src/backend/server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
